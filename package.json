{
	"name": "namedays",
	"version": "5.0.0",
	"description": "Look up namedays by name, date, country, or ID",
	"keywords": [
		"namedays",
		"nameday",
		"name-day",
		"names",
		"calendar",
		"swedish",
		"norwegian",
		"danish",
		"czech",
		"german",
		"polish"
	],
	"homepage": "https://github.com/filiptammergard/namedays#readme",
	"bugs": {
		"url": "https://github.com/filiptammergard/namedays/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/filiptammergard/namedays.git"
	},
	"license": "MIT",
	"author": {
		"name": "Filip Tammergård",
		"email": "filip+npm@tammergard.se",
		"url": "https://tammergard.se"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"main": "dist/index.mjs",
	"types": "dist/index.d.mts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts",
		"format": "prettier --write .",
		"format-check": "prettier --check .",
		"lint": "eslint .",
		"prepublishOnly": "pnpm build",
		"release": "pnpm changeset publish",
		"review": "pnpm install --frozen-lockfile && pnpm format-check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
		"test": "vitest --run",
		"typecheck": "tsc"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@tammergard/eslint-config-base": "^6.1.0",
		"@tammergard/prettier-config": "^3.0.0",
		"@tammergard/tsconfig": "^3.0.0",
		"eslint": "^10.4.0",
		"prettier": "^3.8.3",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	},
	"packageManager": "pnpm@10.33.2",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=24",
			"onFail": "error"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
